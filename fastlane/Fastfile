default_platform :ios

platform :ios do

  desc "Build and upload to TestFlight"
  lane :beta do
    # Creates a temporary keychain on CI and sets MATCH_KEYCHAIN_NAME /
    # MATCH_KEYCHAIN_PASSWORD env vars. Safe no-op locally.
    setup_ci

    # Derive version from git tag (strips leading 'v' and pre-release suffix)
    # e.g. v0.4.0-alpha.1 → 0.4.0
    raw_tag = ENV["RAW_TAG"] || last_git_tag
    without_v = raw_tag.sub(/^v/, "")
    marketing_version = without_v.split("-").first
    build_number = ENV["BUILD_NUMBER"] || number_of_commits.to_s

    UI.message "Version: #{marketing_version} (#{build_number})"

    # Stamp Info.plist
    set_info_plist_value(
      path: "safeflow/Info.plist",
      key: "CFBundleShortVersionString",
      value: marketing_version
    )
    set_info_plist_value(
      path: "safeflow/Info.plist",
      key: "CFBundleVersion",
      value: build_number
    )

    # Import distribution certificate into the keychain setup_ci created
    import_certificate(
      certificate_path: "#{ENV["RUNNER_TEMP"]}/cert.p12",
      certificate_password: ENV["CERTIFICATES_P12_PASSWORD"],
      keychain_name: ENV["MATCH_KEYCHAIN_NAME"],
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"]
    )

    # Install provisioning profile
    install_provisioning_profile(
      path: "#{ENV["RUNNER_TEMP"]}/profile.mobileprovision"
    )

    # Build archive and export IPA
    gym(
      scheme: "safeflow-Beta",
      configuration: "Beta",
      project: "safeflow.xcodeproj",
      export_method: "app-store",
      export_options: {
        teamID: ENV["APPLE_TEAM_ID"],
        provisioningProfiles: {
          "com.thevgergroup.safeflow" => "b6728ec4-c939-4251-8e7b-4ab8f24be2fc"
        },
        uploadSymbols: true,
        compileBitcode: false
      },
      output_directory: "build",
      output_name: "safeflow",
      clean: true
    )

    # Upload to TestFlight
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: false
    )

    pilot(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      notify_external_testers: false,
      ipa: "build/safeflow.ipa"
    )
  end

  desc "Capture App Store screenshots for all languages using SnapshotHelper + xcodebuild"
  lane :screenshots do
    devices = [
      { name: "iPhone 17 Pro Max", udid: "65EC9EE1-D802-4FDA-AC13-4FEC110C0AB4" },
      { name: "iPhone 17",         udid: "B45E0B27-CACF-4857-9405-3B0678587292" },
    ]

    languages = [
      { tag: "en-US", lang: "en-US", locale: "en_US" },
      { tag: "de-DE", lang: "de-DE", locale: "de_DE" },
      { tag: "fr-FR", lang: "fr-FR", locale: "fr_FR" },
      { tag: "es-MX", lang: "es-MX", locale: "es_MX" },
    ]

    # SnapshotHelper reads language/locale from this cache dir and writes PNGs here
    cache_dir = File.expand_path("~/Library/Caches/tools.fastlane")
    screenshots_cache = "#{cache_dir}/screenshots"
    sh("mkdir -p '#{screenshots_cache}'")

    # Boot both simulators once and set status bar
    devices.each do |device|
      UI.message "Booting #{device[:name]}..."
      sh("xcrun simctl boot #{device[:udid]} 2>/dev/null || true")
      sh("xcrun simctl bootstatus #{device[:udid]} -b 2>/dev/null || true")
      sh(
        "xcrun simctl status_bar #{device[:udid]} override " \
        "--time 09:41 --dataNetwork wifi --wifiMode active --wifiBars 3 " \
        "--cellularMode active --cellularBars 4 --batteryState charged --batteryLevel 100"
      )
    end

    languages.each do |language|
      lang_tag = language[:tag]
      lang     = language[:lang]
      locale   = language[:locale]
      out_dir  = File.expand_path("../fastlane/screenshots/#{lang_tag}", __dir__)
      sh("mkdir -p '#{out_dir}'")

      UI.message "=== Capturing #{lang_tag} ==="

      # Write language + locale files for SnapshotHelper to read
      File.write("#{cache_dir}/language.txt", lang)
      File.write("#{cache_dir}/locale.txt", locale)

      devices.each do |device|
        UI.message "  Device: #{device[:name]}"

        # Clear previous screenshots from cache before each device run
        sh("rm -f '#{screenshots_cache}'/*.png")

        sh(
          "set -o pipefail && " \
          "xcodebuild " \
          "-project ../safeflow.xcodeproj " \
          "-scheme safeflow " \
          "-configuration Debug " \
          "-destination 'platform=iOS Simulator,id=#{device[:udid]}' " \
          "-only-testing:safeflowUITests/SnapshotTests " \
          "-skip-testing:safeflowUITests/SnapshotTests/testDiagnostic_WhatIsOnScreen " \
          "FASTLANE_SNAPSHOT=YES " \
          "SIMULATOR_HOST_HOME=#{File.expand_path('~')} " \
          "test 2>&1 | tail -5 || true"
        )

        # Move screenshots from cache to output dir, prefixed by device name
        sh("mv '#{screenshots_cache}'/*.png '#{out_dir}'/ 2>/dev/null || true")
      end

      UI.success "Screenshots for #{lang_tag} saved to #{out_dir}"
    end

    UI.success "All screenshots complete. Check fastlane/screenshots/"
  end

  desc "Distribute a build to an external TestFlight group. Pass group:\"Group Name\" and optionally build_number:\"123\""
  lane :distribute do |options|
    group_name = options[:group] || UI.input("TestFlight external group name:")
    build_number = options[:build_number]

    api_key_args = {
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
    }
    if ENV["ASC_KEY_PATH"]
      api_key_args[:key_filepath] = ENV["ASC_KEY_PATH"]
    else
      api_key_args[:key_content] = ENV["ASC_KEY_CONTENT"]
      api_key_args[:is_key_content_base64] = false
    end
    api_key = app_store_connect_api_key(api_key_args)

    pilot_args = {
      api_key: api_key,
      app_identifier: "com.thevgergroup.safeflow",
      app_platform: "ios",
      distribute_external: true,
      groups: [group_name],
      notify_external_testers: true,
      skip_submission: false,
      skip_waiting_for_build_processing: true,
      changelog: ENV["CHANGELOG"] || "Bug fixes and improvements.",
      distribute_only: true,
    }
    pilot_args[:build_number] = build_number if build_number
    pilot_args[:app_version] = options[:version] if options[:version]

    pilot(pilot_args)
  end

  desc "Poll TestFlight until a build for the given version is processed, then submit for review. Pass version:\"1.0\""
  lane :monitor_and_submit do |options|
    version = options[:version] || UI.input("App Store version number (e.g. 1.0):")
    poll_interval = (options[:interval] || 60).to_i

    api_key_args = {
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
    }
    if ENV["ASC_KEY_PATH"]
      api_key_args[:key_filepath] = ENV["ASC_KEY_PATH"]
    else
      api_key_args[:key_content] = ENV["ASC_KEY_CONTENT"]
      api_key_args[:is_key_content_base64] = false
    end
    api_key = app_store_connect_api_key(api_key_args)

    UI.message "Polling TestFlight for v#{version} build every #{poll_interval}s..."

    build_number = nil
    attempt = 0
    loop do
      attempt += 1
      begin
        build_number = latest_testflight_build_number(
          api_key: api_key,
          app_identifier: "com.thevgergroup.safeflow",
          version: version,
        )
        UI.success "[attempt #{attempt}] Build #{build_number} is ready in TestFlight!"
        break
      rescue => e
        UI.message "[attempt #{attempt}] Not ready yet (#{e.message.split("\n").first}) — retrying in #{poll_interval}s..."
        sleep poll_interval
      end
    end

    UI.message "Submitting v#{version} (build #{build_number}) for App Store review..."

    deliver(
      api_key: api_key,
      app_identifier: "com.thevgergroup.safeflow",
      app_version: version,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      run_precheck_before_submit: false,
      submission_information: {
        # Export compliance
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        export_compliance_is_exempt: true,
        # Age rating — all none/false for a health tracking app
        content_rights_contains_third_party_content: false,
        age_rating_override: "4+",
        # Age rating questionnaire
        kids_age_band: nil,
        unrestricted_web_access: false,
        contests: "NONE",
        gambling: false,
        gambling_and_contests: false,
        sex_or_nudity_graphic: "NONE",
        sex_or_nudity: "NONE",
        violence_cartoon_or_fantasy: "NONE",
        violence_realistic: "NONE",
        violence_realistic_prolonged: "NONE",
        violence_graphic_medical: "NONE",
        profanity_or_crude_humor: "NONE",
        horror_or_fear_themes: "NONE",
        mature_or_suggestive_themes: "NONE",
        simulated_gambling: "NONE",
        gambling_simulation: "NONE",
        medical_or_treatment_information: "NONE",
        health_or_wellness_topics: "NONE",
        alcohol_tobacco_or_drug_use: "NONE",
        alcohol_tobacco_drugs_or_substances: "NONE",
        sexual_content_or_nudity: "NONE",
        loot_box: false,
        user_generated_content: "NONE",
        messaging_and_chat: "NONE",
        advertising: false,
        parental_controls: "NONE",
        guns_or_other_weapons: "NONE",
      }
    )

    UI.success "Submitted! Apple will review within 24-48 hours."
  end

  desc "Set age rating and submit for App Store review directly via Spaceship"
  lane :submit_with_age_rating do |options|
    version = options[:version] || UI.input("App Store version number (e.g. 1.0):")

    api_key_args = {
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
    }
    if ENV["ASC_KEY_PATH"]
      api_key_args[:key_filepath] = ENV["ASC_KEY_PATH"]
    else
      api_key_args[:key_content] = ENV["ASC_KEY_CONTENT"]
      api_key_args[:is_key_content_base64] = false
    end
    api_key = app_store_connect_api_key(api_key_args)

    app_id = "6761509532"

    # Authenticate Spaceship with the API key
    Spaceship::ConnectAPI.auth(
      key_id: api_key[:key_id],
      issuer_id: api_key[:issuer_id],
      filepath: ENV["ASC_KEY_PATH"]
    )

    UI.message "Finding v#{version} edit version..."
    edit_states = "PREPARE_FOR_SUBMISSION,DEVELOPER_REJECTED,REJECTED,METADATA_REJECTED"
    versions_response = Spaceship::ConnectAPI.get_app_store_versions(
      app_id: app_id,
      filter: { platform: "IOS", appStoreState: edit_states }
    )
    app_store_version = versions_response.to_models.find { |v| v.version_string == version }
    UI.user_error!("Could not find v#{version} in an editable state") unless app_store_version
    UI.message "Found version id: #{app_store_version.id}"

    UI.message "Fetching app info for age rating..."
    app_info = Spaceship::ConnectAPI.get_app_infos(app_id: app_id).to_models.find do |info|
      info.app_store_state == "PREPARE_FOR_SUBMISSION" || info.app_store_state.nil?
    end
    app_info ||= Spaceship::ConnectAPI.get_app_infos(app_id: app_id).to_models.first
    UI.user_error!("Could not find app info") unless app_info
    UI.message "App info id: #{app_info.id}"

    UI.message "Fetching age rating declaration..."
    age_rating_response = Spaceship::ConnectAPI.get_age_rating_declaration(
      app_info_id: app_info.id
    )
    age_rating = age_rating_response.to_models.first
    UI.user_error!("Could not find age rating declaration") unless age_rating
    UI.message "Age rating declaration id: #{age_rating.id}"

    UI.message "Setting age rating..."
    Spaceship::ConnectAPI.patch_age_rating_declaration(
      age_rating_declaration_id: age_rating.id,
      attributes: {
        alcoholTobaccoOrDrugUseOrReferences:        "NONE",
        contests:                                    "NONE",
        gambling:                                    false,
        gamblingSimulated:                           "NONE",
        horrorOrFearThemes:                          "NONE",
        matureOrSuggestiveThemes:                    "NONE",
        medicalOrTreatmentInformation:               "NONE",
        profanityOrCrudeHumor:                       "NONE",
        sexualContentGraphicAndNudity:               "NONE",
        sexualContentOrNudity:                       "NONE",
        unrestrictedWebAccess:                       false,
        violenceCartoonOrFantasy:                    "NONE",
        violenceRealistic:                           "NONE",
        violenceRealisticProlongedGraphicOrSadistic: "NONE",
        lootBox:                                     false,
        userGeneratedContent:                        false,
        gunsOrOtherWeapons:                          "NONE",
        parentalControls:                            false,
        healthOrWellnessTopics:                      false,
        ageAssurance:                                false,
        advertising:                                 false,
        messagingAndChat:                            false,
      }
    )
    UI.success "Age rating set."

    UI.message "Setting copyright and review contact info..."
    Spaceship::ConnectAPI.patch_app_store_version(
      app_store_version_id: app_store_version.id,
      attributes: {
        copyright: "#{Time.now.year} The Vger Group"
      }
    )

    # Create review detail (contact info for reviewer)
    begin
      Spaceship::ConnectAPI.post_app_store_review_detail(
        app_store_version_id: app_store_version.id,
        attributes: {
          contactFirstName: "Patrick",
          contactLastName: "O'Leary",
          contactPhone: ENV["REVIEW_CONTACT_PHONE"] || "+1 555 000 0000",
          contactEmail: ENV["APPLE_ID"] || "pjaol@pjaol.com",
          demoAccountRequired: false,
          notes: "This is a privacy-first menstrual cycle tracking app. All data is stored on-device only. No login is required. The app may prompt for Face ID/Touch ID on launch — any biometric works, or tap Cancel to proceed with PIN (no PIN is set on a fresh install)."
        }
      )
    rescue => e
      UI.message "Review detail already exists or could not be created: #{e.message.split("\n").first}"
    end

    UI.message "Creating review submission..."
    submission_response = Spaceship::ConnectAPI.post_review_submission(
      app_id: app_id,
      platform: "IOS"
    )
    submission = submission_response.to_models.first
    UI.message "Review submission id: #{submission.id}"

    UI.message "Adding v#{version} to review submission..."
    Spaceship::ConnectAPI.post_review_submission_item(
      review_submission_id: submission.id,
      app_store_version_id: app_store_version.id
    )

    UI.message "Submitting for App Store review..."
    Spaceship::ConnectAPI.patch_review_submission(
      review_submission_id: submission.id,
      attributes: { state: "SUBMITTED" }
    )
    UI.success "Submitted! Apple will review within 24-48 hours."
  end

  desc "Submit the latest uploaded build for App Store review"
  lane :submit do |options|
    version = options[:version] || UI.input("App Store version number (e.g. 1.0):")

    api_key_args = {
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
    }
    if ENV["ASC_KEY_PATH"]
      api_key_args[:key_filepath] = ENV["ASC_KEY_PATH"]
    else
      api_key_args[:key_content] = ENV["ASC_KEY_CONTENT"]
      api_key_args[:is_key_content_base64] = false
    end
    api_key = app_store_connect_api_key(api_key_args)

    deliver(
      api_key: api_key,
      app_identifier: "com.thevgergroup.safeflow",
      app_version: version,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        export_compliance_is_exempt: true,
      }
    )
  end

  desc "Upload metadata and screenshots to App Store (does not submit for review)"
  lane :metadata do
    # Use key_filepath if ASC_KEY_PATH is set (local dev), otherwise fall back to key_content (CI)
    api_key_args = {
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
    }
    if ENV["ASC_KEY_PATH"]
      api_key_args[:key_filepath] = ENV["ASC_KEY_PATH"]
    else
      api_key_args[:key_content] = ENV["ASC_KEY_CONTENT"]
      api_key_args[:is_key_content_base64] = false
    end
    api_key = app_store_connect_api_key(api_key_args)

    # Upload metadata only first
    deliver(
      api_key: api_key,
      app_identifier: "com.thevgergroup.safeflow",
      skip_binary_upload: true,
      skip_screenshots: true,
      app_icon: "safeflow/Assets.xcassets/AppIcon.appiconset/AppIcon-1024.png",
      submit_for_review: false,
      force: true,
      run_precheck_before_submit: false
    )

    # Upload screenshots separately
    deliver(
      api_key: api_key,
      app_identifier: "com.thevgergroup.safeflow",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      screenshots_path: "fastlane/screenshots",
      overwrite_screenshots: true,
      submit_for_review: false,
      force: true,
      run_precheck_before_submit: false
    )
  end

end
