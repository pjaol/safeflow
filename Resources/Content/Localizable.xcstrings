        "fr" : { "stringUnit" : { "state" : "needs_review", "value" : "Cycle moyen : %lld jours" } }
      }
    },
    "Building accuracy — log more periods for a personalised range" : {
      "comment" : "CyclePhaseCard: not enough data for confident prediction",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "needs_review", "value" : "Genauigkeit wird aufgebaut – protokolliere mehr Perioden für einen personalisierten Bereich." } },
        "es" : { "stringUnit" : { "state" : "needs_review", "value" : "Mejorando la precisión — registra más períodos para un rango personalizado." } },
        "fr" : { "stringUnit" : { "state" : "needs_review", "value" : "Précision en cours — enregistrez plus de règles pour une plage personnalisée." } }
      }
    },
    "Clio Daye is Locked" : {
      "comment" : "LockView headline",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "needs_review", "value" : "Clio Daye ist gesperrt" } },
        "es" : { "stringUnit" : { "state" : "needs_review", "value" : "Clio Daye está bloqueada" } },
        "fr" : { "stringUnit" : { "state" : "needs_review", "value" : "Clio Daye est verrouillée" } }
      }
    },
    "Clio Daye stores all your data on this device only. No cloud, no account, no servers. It is physically impossible for us to access your data." : {
      "comment" : "Onboarding privacy page body",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "needs_review", "value" : "Clio Daye speichert alle deine Daten ausschließlich auf diesem Gerät. Keine Cloud, kein Konto, keine Server. Es ist physisch unmöglich für uns, auf deine Daten zuzugreifen." } },
        "es" : { "stringUnit" : { "state" : "needs_review", "value" : "Clio Daye almacena todos tus datos solo en este dispositivo. Sin nube, sin cuenta, sin servidores. Es físicamente imposible que accedamos a tus datos." } },
        "fr" : { "stringUnit" : { "state" : "needs_review", "value" : "Clio Daye stocke toutes vos données uniquement sur cet appareil. Pas de cloud, pas de compte, pas de serveurs. Il nous est physiquement impossible d'accéder à vos données." } }
      }
    },
    "Clio Daye stores everything on your device only. Nothing is sent to any server, cloud, or third party — ever. No one else can access your cycle data remotely." : {
      "comment" : "Settings privacy explanation",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "needs_review", "value" : "Clio Daye speichert alles ausschließlich auf deinem Gerät. Nichts wird an Server, Cloud oder Dritte gesendet – niemals. Niemand anderes kann aus der Ferne auf deine Zyklusdaten zugreifen." } },
        "es" : { "stringUnit" : { "state" : "needs_review", "value" : "Clio Daye almacena todo solo en tu dispositivo. Nada se envía a ningún servidor, nube o tercero — nunca. Nadie más puede acceder a tus datos del ciclo de forma remota." } },
        "fr" : { "stringUnit" : { "state" : "needs_review", "value" : "Clio Daye stocke tout uniquement sur votre appareil. Rien n'est jamais envoyé à un serveur, un cloud ou un tiers. Personne d'autre ne peut accéder à vos données de cycle à distance." } }
      }
    },
    "Cycle Forecast" : {
      "comment" : "ForecastView title",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "needs_review", "value" : "Zyklusprognose" } },
        "es" : { "stringUnit" : { "state" : "needs_review", "value" : "Pronóstico del ciclo" } },
        "fr" : { "stringUnit" : { "state" : "needs_review", "value" : "Prévision du cycle" } }
      }
    },
    "Cycle overdue" : {
      "comment" : "CycleRingSummaryCard: cycle longer than expected",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "needs_review", "value" : "Zyklus überfällig" } },
        "es" : { "stringUnit" : { "state" : "needs_review", "value" : "Ciclo retrasado" } },
        "fr" : { "stringUnit" : { "state" : "needs_review", "value" : "Cycle en retard" } }
