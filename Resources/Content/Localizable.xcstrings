    "Log your period, symptoms, and mood. Clio Daye learns your pattern and shows you where you are in your cycle every day." : {
      "comment" : "Onboarding tracking page body",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "needs_review", "value" : "Protokolliere deine Periode, Symptome und Stimmung. Clio Daye lernt dein Muster und zeigt dir täglich, wo du dich in deinem Zyklus befindest." } },
        "es" : { "stringUnit" : { "state" : "needs_review", "value" : "Registra tu período, síntomas y estado de ánimo. Clio Daye aprende tu patrón y te muestra cada día dónde estás en tu ciclo." } },
        "fr" : { "stringUnit" : { "state" : "needs_review", "value" : "Enregistrez vos règles, symptômes et humeur. Clio Daye apprend votre schéma et vous indique chaque jour où vous en êtes dans votre cycle." } }
      }
    },
