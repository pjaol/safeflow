    "Add a PIN or Face ID so only you can access Clio Daye." : {
      "comment" : "Onboarding security page subtitle",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "needs_review", "value" : "Füge eine PIN oder Face ID hinzu, damit nur du auf Clio Daye zugreifen kannst." } },
        "es" : { "stringUnit" : { "state" : "needs_review", "value" : "Agrega un PIN o Face ID para que solo tú puedas acceder a Clio Daye." } },
        "fr" : { "stringUnit" : { "state" : "needs_review", "value" : "Ajoutez un code PIN ou Face ID pour que seule vous puissiez accéder à Clio Daye." } }
      }
    },
    "Avg cycle" : {
      "comment" : "Label for average cycle length in cycle detail",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "needs_review", "value" : "Ø Zyklus" } },
        "es" : { "stringUnit" : { "state" : "needs_review", "value" : "Ciclo prom." } },
