    "Cycle running longer than usual" : {
      "comment" : "CycleRingSummaryCard: overdue card title",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "needs_review", "value" : "Zyklus dauert länger als üblich" } },
        "es" : { "stringUnit" : { "state" : "needs_review", "value" : "El ciclo dura más de lo habitual" } },
        "fr" : { "stringUnit" : { "state" : "needs_review", "value" : "Le cycle dure plus longtemps que d'habitude" } }
      }
