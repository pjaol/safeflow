    },
    "These are independent organisations. Clio Daye does not share your data with them. Links open in your browser." : {
      "comment" : "GetSupportView: resource disclaimer",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "needs_review", "value" : "Dies sind unabhängige Organisationen. Clio Daye gibt deine Daten nicht an sie weiter. Links öffnen sich in deinem Browser." } },
        "es" : { "stringUnit" : { "state" : "needs_review", "value" : "Son organizaciones independientes. Clio Daye no comparte tus datos con ellas. Los enlaces se abren en tu navegador." } },
        "fr" : { "stringUnit" : { "state" : "needs_review", "value" : "Ce sont des organisations indépendantes. Clio Daye ne partage pas vos données avec elles. Les liens s'ouvrent dans votre navigateur." } }
      }
    },
