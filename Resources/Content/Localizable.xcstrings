    "Cycle Tracking" : {
      "comment" : "CyclePhaseCard: title when no data yet",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "needs_review", "value" : "Zyklustracking" } },
        "es" : { "stringUnit" : { "state" : "needs_review", "value" : "Seguimiento del ciclo" } },
