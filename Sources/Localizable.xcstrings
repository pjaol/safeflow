    },
    "Your body is doing real work this week. Lighter activity and extra sleep are a good call.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your body is doing real work this week. Lighter activity and extra sleep are a good call."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Körper leistet diese Woche echte Arbeit. Leichtere Aktivität und mehr Schlaf sind eine gute Wahl."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu cuerpo está haciendo un trabajo real esta semana. Actividad más ligera y dormir más es una buena idea."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre corps travaille vraiment cette semaine. Une activité plus légère et un peu plus de sommeil sont une bonne idée."
          }
        }
      },
      "comment": "Phase tip body: menstrual rest"
    },
    "Iron-rich foods": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Iron-rich foods"
          }
        },
        "de": {
          "stringUnit": {
