      "comment": "Phase tip title: menstrual"
    },
    "Anti-inflammatory pain relief (like ibuprofen) works best taken with food at the first sign of cramps, rather than waiting.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Anti-inflammatory pain relief (like ibuprofen) works best taken with food at the first sign of cramps, rather than waiting."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entzündungshemmende Schmerzmittel (wie Ibuprofen) wirken am besten, wenn sie beim ersten Anzeichen von Krämpfen mit einer Mahlzeit eingenommen werden, anstatt zu warten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los analgésicos antiinflamatorios (como el ibuprofeno) funcionan mejor tomados con comida al primer signo de cólicos, en lugar de esperar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
