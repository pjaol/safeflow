          "stringUnit": {
            "state": "translated",
            "value": "A slight rise in basal body temperature after ovulation is normal — it confirms ovulation has occurred."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein leichter Anstieg der Basaltemperatur nach dem Eisprung ist normal — er bestätigt, dass der Eisprung stattgefunden hat."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un ligero aumento de la temperatura corporal basal después de la ovulación es normal — confirma que la ovulación ha ocurrido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
