            "value": "El calor puede ayudar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La chaleur peut aider"
          }
        }
      },
      "comment": "Phase tip title: menstrual"
    },
    "A warm compress or hot water bottle on your lower abdomen may ease cramp discomfort.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A warm compress or hot water bottle on your lower abdomen may ease cramp discomfort."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Wärmflasche oder ein warmes Kompresse auf dem Unterbauch kann Krämpfe lindern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una compresa caliente o una bolsa de agua caliente en el abdomen inferior puede aliviar los cólicos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une bouillotte ou une compresse chaude sur le bas-ventre peut soulager les crampes."
          }
        }
      },
      "comment": "Phase tip body: menstrual heat"
    },
    "Rest is productive": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rest is productive"
          }
        },
        "de": {
