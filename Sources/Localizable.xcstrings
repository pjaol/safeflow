    "Leafy greens, lentils, and beans can help replenish iron lost during your period.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leafy greens, lentils, and beans can help replenish iron lost during your period."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Blattgemüse, Linsen und Bohnen können helfen, das während der Periode verlorene Eisen zu ergänzen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las verduras de hoja verde, las lentejas y los frijoles pueden ayudar a reponer el hierro perdido durante tu período."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les légumes verts, les lentilles et les haricots peuvent aider à reconstituer le fer perdu pendant les règles."
          }
        }
      },
      "comment": "Phase tip body: menstrual iron"
    },
    "Ibuprofen timing": {
      "localizations": {
