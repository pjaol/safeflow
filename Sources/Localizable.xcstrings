    },
    "This will permanently delete all your cycle logs, symptoms, and notes. This cannot be undone.": {
      "comment": "Settings: data deletion confirmation message",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden alle deine Zyklusprotokolle, Symptome und Notizen dauerhaft gelöscht. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará permanentemente todos tus registros de ciclo, síntomas y notas. Esto no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprimera définitivement tous vos journaux de cycle, symptômes et notes. Cette action est irréversible."
          }
        },
        "en": {
