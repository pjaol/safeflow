    "Clio Daye stores all your data on this device only. No cloud, no account, no servers. It is physically impossible for us to access your data.": {
      "comment": "Onboarding privacy page body",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Clio Daye speichert alle deine Daten ausschließlich auf diesem Gerät. Keine Cloud, kein Konto, keine Server. Es ist physisch unmöglich für uns, auf deine Daten zuzugreifen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clio Daye almacena todos tus datos solo en este dispositivo. Sin nube, sin cuenta, sin servidores. Es físicamente imposible que accedamos a tus datos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clio Daye stocke toutes vos données uniquement sur cet appareil. Pas de cloud, pas de compte, pas de serveurs. Il nous est physiquement impossible d'accéder à vos données."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clio Daye stores all your data on this device only. No cloud, no account, no servers. It is physically impossible for us to access your data."
          }
        }
      }
    },
    "Clio Daye stores everything on your device only. Nothing is sent to any server, cloud, or third party — ever. No one else can access your cycle data remotely.": {
      "comment": "Settings privacy explanation",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Clio Daye speichert alles ausschließlich auf deinem Gerät. Nichts wird an Server, Cloud oder Dritte gesendet – niemals. Niemand anderes kann aus der Ferne auf deine Zyklusdaten zugreifen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clio Daye almacena todo solo en tu dispositivo. Nada se envía a ningún servidor, nube o tercero — nunca. Nadie más puede acceder a tus datos del ciclo de forma remota."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clio Daye stocke tout uniquement sur votre appareil. Rien n'est jamais envoyé à un serveur, un cloud ou un tiers. Personne d'autre ne peut accéder à vos données de cycle à distance."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clio Daye stores everything on your device only. Nothing is sent to any server, cloud, or third party — ever. No one else can access your cycle data remotely."
          }
        }
      }
    },
